{
  "name": "campusly-functions",
  "description": "Firebase Cloud Functions pour Campusly",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=property --runInBand --forceExit"
  },
  "engines": { "node": "18" },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.9.0",
    "openai": "^4.47.0"
  },
  "devDependencies": {
    "firebase": "^10.12.0",
    "@firebase/rules-unit-testing": "^3.0.0",
    "jest": "^29.7.0",
    "fast-check": "^3.19.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 30000
  }
}
