rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilisateurs ─────────────────────────────────────
    // Chaque utilisateur peut lire et écrire uniquement son propre profil
    match /users/{uid} {
      // Lecture libre du profil par le propriétaire
      allow read: if request.auth != null && request.auth.uid == uid;
      // Écriture : le propriétaire peut tout modifier SAUF isPremium et premiumExpiry
      allow write: if request.auth != null && request.auth.uid == uid
        && !("isPremium"     in request.resource.data.diff(resource.data).affectedKeys())
        && !("premiumExpiry" in request.resource.data.diff(resource.data).affectedKeys());

      // Sous-collections : historique, favoris, quiz (lecture/écriture propriétaire)
      match /history/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /favorites/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /quizResults/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Épreuves ──────────────────────────────────────────
    // Lecture : tout utilisateur authentifié
    // Écriture : personne côté client (admin SDK uniquement)
    match /epreuves/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Contributions ─────────────────────────────────────
    // Tout utilisateur authentifié peut soumettre
    match /contributions/{id} {
      allow read:   if request.auth != null && resource.data.contributorUid == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Transactions ──────────────────────────────────────
    match /transactions/{id} {
      allow read:  if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Groupes d'étude ───────────────────────────────────
    match /groups/{id} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Forum ─────────────────────────────────────────────
    match /forum/{questionId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;

      match /answers/{answerId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }
  }
}
