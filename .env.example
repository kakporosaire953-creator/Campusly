# ============================================================
# CAMPUSLY — Variables d'environnement
# Copie ce fichier en .env.local et remplis tes vraies valeurs
# ============================================================

# ── Supabase (client) ─────────────────────────────────────────
SUPABASE_URL=https://votre-project.supabase.co
SUPABASE_ANON_KEY=votre-anon-key-ici

# ── Supabase Edge Functions (secrets côté serveur) ───────────
# À configurer via : supabase secrets set NOM=valeur
GROQ_API_KEY=votre-groq-api-key
FEDAPAY_SECRET_KEY=votre-fedapay-secret-key
FEDAPAY_PUBLIC_KEY=votre-fedapay-public-key

# ── Google OAuth ──────────────────────────────────────────────
# À configurer dans Supabase Dashboard → Auth → Providers → Google
# (plus besoin de clés Firebase)
# GOOGLE_CLIENT_ID → dans Supabase Dashboard
# GOOGLE_CLIENT_SECRET → dans Supabase Dashboard
